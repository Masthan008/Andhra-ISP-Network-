{
  "name": "andhra-isp-network-monorepo",
  "version": "1.0.0-enterprise",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --prefix apps/web run dev",
    "dev:all": "turbo run dev",
    "build": "npm --prefix apps/web run build",
    "build:all": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
