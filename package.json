{
  "name": "andhra-isp-network-monorepo",
  "version": "1.0.0-enterprise",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --prefix apps/web run dev",
    "dev:all": "turbo run dev",
    "build": "npm --prefix apps/web run build",
    "build:all": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "cli": "node scripts/cli.js",
    "dev:cli": "node scripts/cli.js",
    "dashboard": "node scripts/dashboard.js",
    "bootstrap": "node scripts/bootstrap.js",
    "validate": "node scripts/validate.js",
    "repair": "node scripts/repair.js",
    "diagnostics": "node scripts/diagnostics.js",
    "health": "node scripts/health.js",
    "reset": "node scripts/reset.js",
    "quality": "node quality/score.js",
    "generate": "node scripts/cli.js generate:component"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
