#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "============================================================"
echo "⚡ ANDHRA ISP NETWORK — COMMIT-MSG HOOK"
echo "============================================================"

# Validate Conventional Commit format: feat|fix|docs|style|refactor|test|chore(scope): description
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9-]+\))?: .+"

if ! echo "$COMMIT_MSG" | grep -Eq "$PATTERN"; then
  echo "❌ Invalid commit message format: \"$COMMIT_MSG\""
  echo "   Format must follow Conventional Commits standard:"
  echo "   feat(ui): add new search filter component"
  echo "   fix(api): resolve CORS preflight header issue"
  echo "   docs(readme): update developer guide"
  exit 1
fi

echo "✅ Conventional commit message format verified."
